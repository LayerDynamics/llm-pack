{
  "source": {
    "include": ["src", "docs"],
    "includePattern": ".js$",
    "excludePattern": "(node_modules/|docs/build/)"
  },
  "plugins": ["plugins/markdown"],
  "opts": {
    "destination": "docs/build",
    "recurse": true,
    "readme": "README.md",
    "template": "node_modules/ink-docstrap/template",
    "static": "./docs/static",
    "css": "./docs/styles/custom.css"
  },
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true,
    "systemName": "LLM-Pack",
    "footer": "Documentation generated by JSDoc",
    "copyright": "2024 LayerDynamics, Unlicense",
    "navType": "vertical",
    "theme": "cyborg",
    "linenums": true,
    "collapseSymbols": false,
    "inverseNav": true,
    "outputSourceFiles": true,
    "outputSourcePath": true,
    "syntaxTheme": "dark",
    "search": true
  },
  "markdown": {
    "parser": "gfm",
    "hardwrap": true
  }
}
