{
  "source": {
    "include": ["src", "docs"],
    "includePattern": ".js$",
    "excludePattern": "(node_modules/|docs/build/)"
  },
  "plugins": ["plugins/markdown"],
  "opts": {
    "destination": "docs/build",
    "recurse": true,
    "readme": "README.md",
    "template": "node_modules/clean-jsdoc-theme",
    "theme_opts": {
      "default_theme": "dark",
      "title": "LLM-Pack Documentation",
      "menu": {
        "GitHub": {
          "href": "https://github.com/LayerDynamics/llm-pack",
          "target": "_blank"
        }
      },
      "meta": [
        {
          "name": "author",
          "content": "LayerDynamics"
        }
      ],
      "search": true,
      "create_style": true,
      "include_css": ["./docs/styles/custom.css"]
    }
  },
  "markdown": {
    "parser": "gfm",
    "hardwrap": true
  }
}
