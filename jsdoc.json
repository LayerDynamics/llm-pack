{
  "source": {
    "include": ["src", "docs"],
    "includePattern": ".js$",
    "excludePattern": "(node_modules/|docs/build/)"
  },
  "plugins": ["plugins/markdown"],
  "opts": {
    "destination": "docs/build",
    "recurse": true,
    "readme": "README.md",
    "template": "node_modules/clean-jsdoc-theme"
  },
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true
  },
  "search": true,
  "theme_opts": {
    "default_theme": "dark",
    "title": "LLM-Pack Documentation",
    "homePage": "README.md",
    "menu": [
      {
        "title": "GitHub",
        "link": "https://github.com/LayerDynamics/llm-pack",
        "target": "_blank"
      },
      {
        "title": "NPM",
        "link": "https://www.npmjs.com/package/llm-pack",
        "target": "_blank"
      }
    ],
    "meta": [
      {
        "name": "author",
        "content": "Ryan O'Boyle, LayerDynamics"
      }
    ],
    "create_style": true,
    "include_css": ["./docs/styles/custom.css"],
    "sections": ["Classes", "Modules", "Global"],
    "search": true,
    "resizeable": {
      "navbar": {
        "min": "300",
        "max": "600"
      }
    }
  }
}
